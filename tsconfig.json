{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "actaro": ["./src/index.ts"]
    }
  },
  "include": ["src", "test", "examples", "tsup.config.ts", "vitest.config.ts"]
}
