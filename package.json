{
  "name": "actaro",
  "version": "0.1.0",
  "description": "Verify that AI agent actions produced their intended real-world effects.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "actaro": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "docs:build": "typedoc --out docs/api src/index.ts --plugin typedoc-plugin-markdown --readme none --githubPages false --hideGenerator --skipErrorChecking",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "keywords": [
    "ai",
    "agents",
    "verification",
    "mcp",
    "receipts"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^20.19.9",
    "eslint": "^9.31.0",
    "openai": "^6.48.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
